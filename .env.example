# Copy this file to .env and adjust values for your local environment.
# .env is gitignored (see .gitignore): never commit real secrets, only this
# example file with placeholder values.
#
# docker compose reads .env automatically from the project root to fill in
# the ${VAR} references in docker-compose.yml.

POSTGRES_DB=spring_boot_tutorial
POSTGRES_USER=spring_boot_tutorial
POSTGRES_PASSWORD=spring_boot_tutorial

DB_URL=jdbc:postgresql://db:5432/spring_boot_tutorial
DB_USERNAME=spring_boot_tutorial
DB_PASSWORD=spring_boot_tutorial

JWT_SECRET=docker-compose-demo-jwt-secret-please-override-in-real-prod-987654321
